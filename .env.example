# Neon Postgres connection string (https://console.neon.tech → your project → Connection string)
DATABASE_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# BetterAuth — generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-a-long-random-string"
# Base URL of the app (no trailing slash). Use http://localhost:3000 in dev.
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com → Credentials → OAuth client ID → Web).
# Authorized redirect URI: <BETTER_AUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
